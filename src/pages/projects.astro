---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.year - a.data.year || a.data.title.localeCompare(b.data.title)
);
---

<Layout
  title="Projects | DataSquad International"
  description="Cross-institution work and outputs produced by DataSquad student analysts across the network."
>
  <section class="hero">
    <div class="inner">
      <p class="eyebrow">Student work</p>
      <h1>Projects</h1>
      <p class="lede">
        Cross-institution work and outputs produced by DataSquad student analysts.
      </p>
    </div>
  </section>

  <section class="section">
    {projects.length === 0 ? (
      <div class="empty">
        <p>
          We're collecting standout work from across the network. In the meantime,
          recent updates and project recaps live on the <a href="/blog">blog</a>.
        </p>
        <p class="small">
          Run a DataSquad and have work to feature? <a href="/contact">Get in touch</a>.
        </p>
      </div>
    ) : (
      <ul class="cards">
        {projects.map((p) => (
          <li class="card">
            <div class="meta">
              <span class="year">{p.data.year}</span>
              {p.data.institutions.map((inst) => <span class="inst">{inst}</span>)}
            </div>
            <h2>
              {p.data.url ? (
                <a href={p.data.url} target="_blank" rel="noopener">{p.data.title} ↗</a>
              ) : p.data.title}
            </h2>
            <p class="desc">{p.data.description}</p>
            {p.data.contributors.length > 0 && (
              <p class="by">By {p.data.contributors.join(', ')}</p>
            )}
            {p.data.tags.length > 0 && (
              <ul class="tags">{p.data.tags.map((t) => <li>{t}</li>)}</ul>
            )}
          </li>
        ))}
      </ul>
    )}
  </section>
</Layout>

<style>
  .hero { background: var(--color-navy); color: var(--color-white); }
  .hero .inner { max-width: var(--max-width); margin: 0 auto; padding: var(--space-16) var(--space-6); }
  .eyebrow {
    margin: 0 0 var(--space-3); font-size: var(--text-xs); letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--color-orange); font-weight: 700;
  }
  .hero h1 { margin: 0 0 var(--space-4); color: var(--color-white); font-size: var(--text-4xl); }
  .lede { margin: 0; font-size: var(--text-lg); color: #cdd6e3; max-width: 60ch; }

  .section { max-width: var(--max-width); margin: 0 auto; padding: var(--space-12) var(--space-6); }
  .empty { max-width: 60ch; }
  .empty p { font-size: var(--text-lg); color: #555; margin: 0 0 var(--space-4); }
  .empty .small { font-size: var(--text-base); color: var(--color-muted); }
  .empty a { color: var(--color-link); font-weight: 700; text-decoration: none; }

  .cards {
    list-style: none; margin: 0; padding: 0; display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: var(--space-6);
  }
  .card {
    background: var(--color-white); border: 1px solid #e3e6ea;
    border-top: 3px solid var(--color-steel); border-radius: 0 0 8px 8px; padding: var(--space-6);
  }
  .meta { display: flex; flex-wrap: wrap; gap: var(--space-2); align-items: center; margin-bottom: var(--space-2); }
  .year { color: var(--color-link); font-weight: 700; font-size: var(--text-sm); }
  .inst { color: var(--color-muted); font-size: var(--text-xs); }
  .card h2 { margin: 0 0 var(--space-2); font-size: var(--text-xl); }
  .card h2 a { text-decoration: none; color: var(--color-navy); }
  .card h2 a:hover { color: var(--color-link); }
  .desc { margin: 0 0 var(--space-3); color: #555; font-size: var(--text-sm); line-height: 1.6; }
  .by { margin: 0; color: var(--color-muted); font-size: var(--text-sm); }
  .tags { list-style: none; margin: var(--space-3) 0 0; padding: 0; display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .tags li { background: #eef1f4; color: var(--color-navy); border-radius: 12px; padding: 2px var(--space-3); font-size: var(--text-xs); }

  @media (max-width: 720px) { .hero h1 { font-size: var(--text-3xl); } }
</style>
