---
import Layout from '../layouts/Layout.astro';
import PersonCard from '../components/PersonCard.astro';
import { getCollection } from 'astro:content';

const people = await getCollection('people');

const GROUPS = [
  {
    title: 'Staff & contributors',
    blurb: 'The people who run and support the network.',
    statuses: ['lead', 'staff'],
    cluster: false,
  },
  {
    title: 'Current analysts',
    blurb: 'Students doing the data work right now.',
    statuses: ['current'],
    cluster: true,
  },
];

const byGroup = GROUPS.map((g) => ({
  ...g,
  members: people
    .filter((p) => g.statuses.includes(p.data.status))
    .sort(
      (a, b) =>
        (g.cluster ? a.data.institution.localeCompare(b.data.institution) : 0) ||
        a.data.order - b.data.order ||
        a.data.name.localeCompare(b.data.name)
    ),
})).filter((g) => g.members.length > 0);

const alumniCount = people.filter((p) => p.data.status === 'alumni').length;
---

<Layout
  title="People | DataSquad International"
  description="The leads, staff, and current student analysts behind the DataSquad International network."
>
  <section class="people-hero">
    <div class="inner">
      <p class="eyebrow">Who we are</p>
      <h1>People</h1>
      <p class="lede">
        DataSquad is run by students, supported by staff, and built across
        institutions. Here's who makes it happen.
      </p>
    </div>
  </section>

  {byGroup.map((group) => (
    <section class="group">
      <header class="group-head">
        <h2>{group.title}</h2>
        <p>{group.blurb}</p>
      </header>
      <ul class="cards">
        {group.members.map((person) => <PersonCard person={person} />)}
      </ul>
    </section>
  ))}

  {alumniCount > 0 && (
    <section class="group alumni-cta">
      <h2>Alumni</h2>
      <p>
        {alumniCount} DataSquad members have moved on to graduate programs,
        industry, and research roles around the world.
      </p>
      <a class="btn" href="/alumni">Visit the Hall of Fame →</a>
    </section>
  )}
</Layout>

<style>
  .people-hero {
    background: var(--color-navy);
    color: var(--color-white);
  }
  .people-hero .inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-12) var(--space-6);
  }
  .eyebrow {
    margin: 0 0 var(--space-2);
    font-size: var(--text-xs);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-orange);
    font-weight: 700;
  }
  .people-hero h1 {
    margin: 0 0 var(--space-3);
    color: var(--color-white);
    font-size: var(--text-4xl);
  }
  .lede {
    margin: 0;
    color: #cdd6e3;
    font-size: var(--text-lg);
    max-width: 54ch;
  }

  .group {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-12) var(--space-6) 0;
  }
  .group-head h2 {
    margin: 0 0 var(--space-1);
    font-size: var(--text-2xl);
  }
  .group-head p {
    margin: 0 0 var(--space-6);
    color: var(--color-muted);
  }

  .cards {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-6);
  }

  .alumni-cta {
    padding-top: var(--space-12);
    padding-bottom: var(--space-8);
  }
  .alumni-cta h2 {
    margin: 0 0 var(--space-2);
    font-size: var(--text-2xl);
  }
  .alumni-cta p {
    margin: 0 0 var(--space-4);
    color: var(--color-muted);
    max-width: 60ch;
  }
  .alumni-cta .btn {
    display: inline-block;
    background: var(--color-orange);
    color: var(--color-slate);
    font-weight: 700;
    text-decoration: none;
    border-radius: 6px;
    padding: var(--space-3) var(--space-6);
  }
  .alumni-cta .btn:hover {
    background: #ffbe3d;
  }
</style>
