---
const nav = [
  { href: '/about', label: 'About' },
  { href: '/model', label: 'Model' },
  { href: '/institutions', label: 'Institutions' },
  { href: '/people', label: 'People' },
  { href: '/blog', label: 'Blog' },
  { href: '/projects', label: 'Projects' },
  { href: '/join', label: 'Join', cta: true },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <div class="header-inner">
    <a class="brand" href="/">
      <img src="/datasquad_international_logo.png" alt="" width="32" height="32" />
      <span class="brand-name">DataSquad International</span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" hidden />
    <label for="nav-toggle" class="nav-burger" aria-label="Toggle navigation">
      <span></span><span></span><span></span>
    </label>

    <nav class="site-nav" aria-label="Primary">
      {nav.map(({ href, label, cta }) => (
        <a
          href={href}
          class:list={['nav-link', { cta, active: pathname === href }]}
          aria-current={pathname === href ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-navy);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-3) var(--space-6);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }
  .brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
  }
  .brand img {
    border-radius: 6px;
    display: block;
  }
  .brand-name {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--color-white);
  }
  .site-nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }
  .nav-link {
    color: #cdd6e3;
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 500;
    padding: var(--space-1) 0;
    border-bottom: 2px solid transparent;
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--color-white);
    border-bottom-color: var(--color-orange);
  }
  .nav-link.cta {
    color: var(--color-orange);
  }
  .nav-link.cta:hover {
    color: var(--color-orange);
    border-bottom-color: var(--color-orange);
  }

  .nav-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: var(--space-2);
  }
  .nav-burger span {
    width: 22px;
    height: 2px;
    background: var(--color-white);
    border-radius: 2px;
  }

  @media (max-width: 640px) {
    .nav-burger {
      display: flex;
    }
    .site-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      background: var(--color-navy);
      padding: var(--space-2) var(--space-6) var(--space-4);
    }
    .nav-toggle:checked ~ .site-nav {
      display: flex;
    }
    .nav-link {
      width: 100%;
      padding: var(--space-3) 0;
    }
  }
</style>
